<Window x:Class="Cypres2._0.Views.ManoDeObra.ManoDeObra"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Cypres2._0.Views.ManoDeObra"
        mc:Ignorable="d"
        
        xmlns:UserControls="clr-namespace:Cypres2._0.Views.ManoDeObra.UserControls"
        
        lex:LocalizeDictionary.DesignCulture="es"
        xmlns:lex="http://wpflocalizeextension.codeplex.com"
        lex:ResxLocalizationProvider.DefaultAssembly="Cypres2._0"
        lex:ResxLocalizationProvider.DefaultDictionary="Properties.Resources.ManoDeObra.Strings"
        
        Title="Mano de Obra" Height="700" Width="1200">

     <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="71"/>
            <RowDefinition/>
            <RowDefinition Height="20"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="39"/>
            </Grid.RowDefinitions>

            <UserControls:MenuBar Grid.Row="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
            <Rectangle Grid.Row="1" Fill="White" HorizontalAlignment="Stretch"/>
            <UserControls:TopButtonPanel Grid.Row="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="15*"/>
                </Grid.RowDefinitions>


                <Border Grid.Row="1" BorderBrush="{StaticResource MenuBackgroundBrush}" Margin="20"
                        BorderThickness="1"
                        CornerRadius="5"
                        SnapsToDevicePixels="True">
                    <ListView BorderThickness="0"
                        ItemsSource="{Binding FamiliaManoDeObra}"  
                        DisplayMemberPath="Descripcion">
                    </ListView>

                </Border>
            </Grid>

            <Grid Grid.Column="1">
                <DataGrid 
                    ItemsSource="{Binding ManoDeObraGridDto}"></DataGrid>
            </Grid>

        </Grid>
    </Grid>
</Window>
