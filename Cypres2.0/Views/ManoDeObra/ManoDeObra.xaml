<Window x:Class="Cypres2._0.Views.ManoDeObra.ManoDeObra"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Cypres2._0.Views.ManoDeObra"
        mc:Ignorable="d"
        
        xmlns:UserControls="clr-namespace:Cypres2._0.Views.ManoDeObra.UserControls"
        
        xmlns:lex="http://wpflocalizeextension.codeplex.com"
        lex:LocalizeDictionary.DesignCulture="es"
        lex:ResxLocalizationProvider.DefaultAssembly="Cypres2.0"
        lex:ResxLocalizationProvider.DefaultDictionary="Properties.Resources.ManoDeObra.Strings"
        
        Title="Mano de Obra" Height="700" Width="1500">

     <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="71"/>
            <RowDefinition/>
            <RowDefinition Height="20"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="39"/>
            </Grid.RowDefinitions>

            <UserControls:MenuBar Grid.Row="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
            <Rectangle Grid.Row="1" Fill="White" HorizontalAlignment="Stretch"/>
            <UserControls:TopButtonPanel Grid.Row="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Button Grid.Row="0"
                    Content="{lex:Loc BotonListadoGeneral}"
                    HorizontalAlignment="Left"
                    Margin="20,20,0,0"
                    Padding="12,5"
                    Cursor="Hand"
                    Panel.ZIndex="1"
                    Command="{Binding ListadoGeneralCommand}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#E8EEF4"/>
                            <Setter Property="BorderBrush" Value="#CCCCCC"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="FontFamily" Value="{StaticResource SecondaryFont}"/>
                            <Setter Property="FontSize" Value="{StaticResource FontSizeNormal}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1,1,1,0"
                                    CornerRadius="4,4,0,0"
                                    Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#D4E4F0"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter Property="Background" Value="#D0D0D0"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>


                <Border Grid.Row="1" BorderBrush="{StaticResource BorderColor}" Margin="20,0,20,20"
                        BorderThickness="1"
                        CornerRadius="0,5,5,5"
                        SnapsToDevicePixels="True">

                    <Grid>
                        <Grid.OpacityMask>
                            <VisualBrush Visual="{Binding ElementName=border}"/>
                        </Grid.OpacityMask>
                        <Border
                            x:Name="border"
                            Background="White"
                            CornerRadius="0,5,5,5"/>
                        <ListView BorderThickness="0"
                                FontFamily="{StaticResource SecondaryFont}"
                                FontSize="{StaticResource FontSizeNormal}"
                                FontWeight="Bold"
                                ItemsSource="{Binding FamiliaManoDeObra}"  
                                DisplayMemberPath="Descripcion"
                                  SelectedItem="{Binding SelectedFamilia}">

                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Padding" Value="10,5,0,5"/>
                                    <Setter Property="Margin" Value="0"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="20*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="1" BorderBrush="{StaticResource BorderColor}" Margin="20"
                    BorderThickness="1"
                    CornerRadius="5"
                    SnapsToDevicePixels="True">
                    <UserControls:ManoDeObraDataGrid
                        ItemsSource="{Binding ManoDeObraGridDto}">

                    </UserControls:ManoDeObraDataGrid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
