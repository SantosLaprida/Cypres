<UserControl x:Class="Cypres2._0.Views.ManoDeObra.UserControls.ManoDeObraDataGrid"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Cypres2._0.Views.ManoDeObra.UserControls"
             xmlns:lex="http://wpflocalizeextension.codeplex.com"
            lex:LocalizeDictionary.DesignCulture="es"
            lex:ResxLocalizationProvider.DefaultAssembly="Cypres2.0"
            lex:ResxLocalizationProvider.DefaultDictionary="Properties.Resources.ManoDeObra.Strings"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
    
    <UserControl.Resources>
        <Style x:Key="LeftCell" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="5,0,0,0"/>
        </Style>
        <Style x:Key="RightCell" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
        </Style>
        <Style x:Key="CenterCheckBox" TargetType="CheckBox">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>
   
    <DataGrid
        ItemsSource="{Binding ItemsSource, 
            RelativeSource={RelativeSource AncestorType=UserControl}}"
        AutoGenerateColumns="False"
        BorderThickness="0"
        CanUserAddRows="False"
        HeadersVisibility="Column"
        ColumnHeaderHeight="35"
        RowHeight="30"
        FontSize="{StaticResource FontSizeNormal}"
        FontFamily="{StaticResource SecondaryFont}">

        <DataGrid.ColumnHeaderStyle>
            <Style TargetType="DataGridColumnHeader">
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
            </Style>
        </DataGrid.ColumnHeaderStyle>
        <DataGrid.Columns>
            <DataGridTextColumn Header="{lex:Loc GridCodigo}"      
                                Binding="{Binding Id}"      
                                Width="0.5*" 
                                ElementStyle="{StaticResource LeftCell}"/>
            <DataGridTextColumn Header="{lex:Loc GridDescripcion}" 
                                Binding="{Binding Descripcion}" 
                                Width="1.5*"
                                ElementStyle="{StaticResource LeftCell}"/>
            <DataGridTextColumn Header="{lex:Loc GridUnidad}"      
                                Binding="{Binding Unidad}"      
                                Width="0.5*"
                                ElementStyle="{StaticResource LeftCell}"/>
            <DataGridTextColumn Header="{lex:Loc GridMoneda}"      
                                Binding="{Binding Moneda}"      
                                Width="0.5*"
                                ElementStyle="{StaticResource LeftCell}"/>
            <DataGridTextColumn Header="{lex:Loc GridC_Origen}"   
                                Binding="{Binding COrigen, StringFormat=N2}" 
                                Width="0.7*" 
                                ElementStyle="{StaticResource RightCell}"/>
            <DataGridTextColumn Header="{lex:Loc GridC_Final}"    
                                Binding="{Binding CFinal,  StringFormat=N2}" 
                                Width="0.7*"
                                ElementStyle="{StaticResource RightCell}"/>
            <DataGridCheckBoxColumn Header="{lex:Loc GridRevisado}"   
                                    Binding="{Binding Revisado}"   
                                    Width="0.5*" 
                                    ElementStyle="{StaticResource CenterCheckBox}"/>
            <DataGridTextColumn Header="{lex:Loc GridFecha}"      
                                Binding="{Binding Fecha,   
                                StringFormat=dd/MM/yyyy}" Width="0.6*"/>
        </DataGrid.Columns>


    </DataGrid>
</UserControl>
