<UserControl x:Class="Cypres2._0.Views.ManoDeObra.UserControls.MenuBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Cypres2._0.Views.ManoDeObra.UserControls"
             
             xmlns:lex="http://wpflocalizeextension.codeplex.com"
             lex:LocalizeDictionary.DesignCulture="es"
             lex:ResxLocalizationProvider.DefaultAssembly="Cypres2.0"
             lex:ResxLocalizationProvider.DefaultDictionary="Properties.Resources.ManoDeObra.Strings"
             
             mc:Ignorable="d"
             d:DesignHeight="30" d:DesignWidth="800">

    <Grid>
        <!-- No Background needed here — handled by App.xaml style -->
        <Menu Height="40" VerticalContentAlignment="Center">
            <MenuItem Header="{lex:Loc MenuArchivo}" >
                <MenuItem Header="{lex:Loc SubMenuCrear}" />
                <MenuItem Header="{lex:Loc SubMenuEliminar}" />
                <MenuItem Header="{lex:Loc SubMenuEditar}" />
                <MenuItem Header="{lex:Loc SubMenuEliminarManoDeObraSinUso}" />
                <MenuItem Header="{lex:Loc SubMenuSalir}" />
            </MenuItem>

            <MenuItem Header="{lex:Loc MenuFamilia}">
                <MenuItem Header="{lex:Loc SubMenuCrear}" 
                          Command="{Binding CrearFamiliaCommand}"/>
                <MenuItem Header="{lex:Loc SubMenuEliminar}"
                          Command="{Binding EliminarFamiliaCommand}"/>
                <MenuItem Header="{lex:Loc SubMenuEditar}" 
                          Command="{Binding EditarFamiliaCommand}"/>
            </MenuItem>

            <MenuItem Header="{lex:Loc MenuPrecios}">
                <MenuItem Header="{lex:Loc SubMenuFamiliaAplicarFactor}" />
                <MenuItem Header="{lex:Loc SubMenuMonedaAplicarFactor}" />
            </MenuItem>

            <MenuItem Header="{lex:Loc MenuImportar}">
                <MenuItem Header="{lex:Loc SubMenuDeProyecto}" />
            </MenuItem>
        </Menu>
    </Grid>
</UserControl>